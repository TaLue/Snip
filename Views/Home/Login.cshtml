@{
    ViewData["Title"] = "Login";
}

<div class="mt-24 max-w-sm mx-auto">
    <h1 class="text-2xl font-bold mb-6 text-center">Dashboard Login</h1>

    @if (ViewBag.Error != null)
    {
        <div class="bg-red-900/30 border border-red-700 rounded-lg p-3 mb-4 text-red-400 text-sm">
            @ViewBag.Error
        </div>
    }

    <form action="/login" method="post" class="space-y-4">
        <div>
            <label class="block text-sm text-gray-400 mb-1">Password</label>
            <input type="password" name="password" autofocus
                   class="w-full bg-gray-900 border border-gray-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-indigo-500 transition" />
        </div>
        <button type="submit"
                class="w-full bg-indigo-600 hover:bg-indigo-500 text-white font-semibold py-3 rounded-lg transition">
            Login
        </button>
    </form>
</div>
