@using Snip.Models
@model ShortLink
@{
    ViewData["Title"] = $"/{Model.Slug}";

    var clicksByDay = Model.Clicks
        .GroupBy(c => c.ClickedAt.Date)
        .OrderBy(g => g.Key)
        .Select(g => new { date = g.Key.ToString("MMM d"), count = g.Count() })
        .ToList();

    var topReferrers = Model.Clicks
        .GroupBy(c => string.IsNullOrEmpty(c.Referrer) ? "Direct" : c.Referrer)
        .OrderByDescending(g => g.Count())
        .Take(5)
        .Select(g => new { source = g.Key, count = g.Count() })
        .ToList();
}

<div class="mb-6">
    <a href="/dashboard" class="text-sm text-gray-500 hover:text-white transition">← Dashboard</a>
</div>

<div class="bg-gray-900 border border-gray-800 rounded-lg p-5 mb-6">
    <div class="flex items-start justify-between gap-4">
        <div class="min-w-0">
            <div class="flex items-center gap-2 mb-1">
                <span class="text-xl font-mono text-indigo-400">/@Model.Slug</span>
                @if (!Model.IsActive)
                {
                    <span class="text-xs bg-gray-700 text-gray-400 px-2 py-0.5 rounded">inactive</span>
                }
            </div>
            @if (!string.IsNullOrEmpty(Model.Label))
            {
                <div class="text-sm text-white mb-1">@Model.Label</div>
            }
            <div class="text-sm text-gray-500 truncate">@Model.OriginalUrl</div>
            <div class="text-xs text-gray-700 mt-1">Created @Model.CreatedAt.ToString("dd MMM yyyy")</div>
        </div>
        <div class="text-right shrink-0">
            <div class="text-3xl font-bold">@Model.Clicks.Count</div>
            <div class="text-xs text-gray-500">total clicks</div>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="bg-gray-900 border border-gray-800 rounded-lg p-5">
        <h2 class="text-sm font-semibold text-gray-400 mb-4">Clicks over time</h2>
        @if (clicksByDay.Any())
        {
            <canvas id="clickChart"></canvas>
        }
        else
        {
            <p class="text-gray-600 text-sm">No data yet.</p>
        }
    </div>

    <div class="bg-gray-900 border border-gray-800 rounded-lg p-5">
        <h2 class="text-sm font-semibold text-gray-400 mb-4">Top referrers</h2>
        @if (topReferrers.Any())
        {
            <div class="space-y-2">
                @foreach (var r in topReferrers)
                {
                    <div class="flex justify-between items-center text-sm">
                        <span class="text-gray-300 truncate max-w-[200px]">@r.source</span>
                        <span class="text-white font-semibold">@r.count</span>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-gray-600 text-sm">No data yet.</p>
        }
    </div>
</div>

@section Scripts {
    @if (clicksByDay.Any())
    {
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <script>
            const ctx = document.getElementById('clickChart');
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(clicksByDay.Select(c => c.date))),
                    datasets: [{
                        data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(clicksByDay.Select(c => c.count))),
                        backgroundColor: '#6366f1',
                        borderRadius: 4,
                    }]
                },
                options: {
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { ticks: { color: '#6b7280' }, grid: { color: '#1f2937' } },
                        y: { ticks: { color: '#6b7280', stepSize: 1 }, grid: { color: '#1f2937' } }
                    }
                }
            });
        </script>
    }
}
